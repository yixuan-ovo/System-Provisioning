# Docker Compose 环境变量示例文件
#
# 使用方法：
# 1. 在服务器上复制一份：cp .env.example .env
# 2. 修改 .env 里的真实值
# 3. .env 可以留在服务器本地，不要提交到 GitHub
#
# 注意：
# - 这个文件是示例，可以提交到仓库
# - 真正的 .env 里可能包含密码、Token、真实地址，不建议公开
# - Docker Compose 会自动读取同目录下的 .env
# - 只有 docker-compose.yml 里写了 ${变量名}，这里的变量才会生效


# ===== Tailscale / 尾网配置 =====

# 服务器的 Tailscale IP。
# 查看命令：tailscale ip
# 公开仓库里建议保留示例值；真实值写到服务器本地的 .env。
# docker-compose.yml 已经使用 ${TAILSCALE_IP}，复制成 .env 后改这里即可。
TAILSCALE_IP=100.64.0.10

# 服务器的 Tailscale MagicDNS 完整域名。
# Uptime Kuma 监控项建议写完整域名，不要只写短名，避免尾网名变化或 DNS search 不一致。
# 当前 compose 不直接使用这个变量，主要用于记录和配置监控项。
TAILSCALE_DOMAIN=your-device.your-tailnet.ts.net


# ===== 服务端口 =====

# Uptime Kuma 使用 host 网络模式，端口由应用自身监听。
UPTIME_KUMA_PORT=12861

# FileCodeBox 文件分享服务端口。
FILECODEBOX_PORT=26861

# Excalidraw 在线绘图服务端口。
EXCALIDRAW_PORT=23971

# Sun-Panel 入口面板端口。
# 当前 compose 里 Sun-Panel 保留全网卡监听 80:3002，用于入口面板和检测服务状态。
# 这里只控制宿主机端口，不绑定 Tailscale IP。
SUN_PANEL_PORT=80

# Kula 系统监控端口，当前通过 KULA_PORT 环境变量传给容器。
KULA_PORT=61208

# SyncTV 同步播放服务端口。
SYNCTV_PORT=23862

# WebDAV 同步服务端口。
# 当前 compose 保留全网卡监听，方便不同软件客户端同步；公网暴露时务必配强密码和防火墙。
WEBDAV_PORT=22263


# ===== WebDAV 同步配置 =====

# WebDAV 认证方式，bytemark/webdav 常用 Basic。
WEBDAV_AUTH_TYPE=Basic

# WebDAV 用户名。
# 这里是示例值，真实部署时请在 .env 里改成自己的用户名。
WEBDAV_USERNAME=your_username

# WebDAV 密码。
# 这里必须换成强密码；真实密码只写在 .env，不要提交到 GitHub。
WEBDAV_PASSWORD=change_me_to_a_strong_password


# ===== 可选：本地 Alist / 媒体库配置 =====

# 如果你在 Windows 或其他个人设备上运行 Alist，可以填写那台设备的 Tailscale 地址。
# 服务器上的 SyncTV 可以通过这个地址访问你的本地媒体库。
LOCAL_ALIST_TAILSCALE_HOST=100.64.0.20

# 本地 Alist 默认端口。
LOCAL_ALIST_PORT=5244

# Alist 中用于媒体库的路径示例。
LOCAL_ALIST_MEDIA_PATH=/local
